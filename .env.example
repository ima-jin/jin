# Jin app shell — environment example
# Copy to .env.local and fill in. No hardcoded URLs in code — everything comes from env.

# --- Ports (userspace client app; dev 3402 / prod 7402) ---
PORT=3402

# --- Imajin kernel (auth / media / mcp live here) ---
# Dev kernel front door
IMAJIN_KERNEL_URL=https://dev-jin.imajin.ai
# Auth endpoint base (DID challenge/verify). Path prefix on the kernel.
IMAJIN_AUTH_URL=https://dev-jin.imajin.ai/auth

# --- Session cookie ---
# Must be scoped to .imajin.ai so a session is valid across imajin.ai AND jin.imajin.ai.
SESSION_COOKIE_DOMAIN=.imajin.ai

# --- Presence / agent backend (WS) ---
# The agent backend connects ONLY after a verified session. Never reachable unauthed.
PRESENCE_WS_URL=

# --- OSC fan-out (optional; presence/telemetry only, never auth) ---
# Targets that ambient object state fans out to (Unit, Sonos). Leave empty to disable.
OSC_FANOUT_TARGETS=

# --- Environment ---
NODE_ENV=development
